# ── Firebase Admin SDK ──
# Ve a Firebase Console → Configuración del proyecto → Cuentas de servicio
# → Generar nueva clave privada → Descarga el JSON
# Copia los valores del JSON aquí:

FIREBASE_PROJECT_ID=elcorazondematias
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@elcorazondematias.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# ── Puerto del servidor ──
PORT=3000
